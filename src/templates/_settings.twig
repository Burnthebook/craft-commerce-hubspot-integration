{# @var plugin \burnthebook\craftcommercehubspotintegration\CommerceHubspotIntegration #}
{# @var settings \burnthebook\craftcommercehubspotintegration\models\Settings #}

{% import '_includes/forms.twig' as forms %}
{{ 
    forms.textField({
        first: true,
        label: 'Hubspot API Base URL (with http(s)://)',
        instructions: "Required - the base URL to the Hubspot API",
        id: 'hubspotApiBaseUrl',
        name: 'hubspotApiBaseUrl',
        required: true,
        value: settings.hubspotApiBaseUrl
    }) 
}}
{{ 
    forms.autosuggestField({
        label: 'HubSpot Private App Token',
        instructions: 'Required - Your HubSpot private app token (Bearer token value only).',
        id: 'hubspotPrivateAppToken',
        name: 'hubspotPrivateAppToken',
        required: true,
        suggestEnvVars: true,
        value: settings.hubspotPrivateAppToken
    }) 
}}

<div class="field">
    <div class="heading">
        <label>{{ 'Connection Test'|t('craft-commerce-hubspot-integration') }}</label>
    </div>
    <div class="instructions">
        <p>Checks if the saved base URL and token can reach HubSpot.</p>
    </div>
    <div class="input ltr">
        <a class="btn" href="{{ actionUrl('craft-commerce-hubspot-integration/hubspot/test-connection') }}">Test HubSpot Connection</a>
    </div>
</div>
